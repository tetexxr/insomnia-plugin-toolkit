{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2021",
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2021"],
    "types": ["node"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node16",
    "resolveJsonModule": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "test"]
}
